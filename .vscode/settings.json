    "**/__pycache__/**": true,
    "**/_build/**": true,
    "**/_site/**": true,
    "**/build/**": true,
    "**/docs/reference-studies/my-awesome-app/dist/**": true,
    "**/docs/reference-studies/my-awesome-app/node_modules/**": true,
    "**/frontend/dist/**": true,
    "**/frontend/node_modules/**": true,
    "**/resources/**": true,
    "**/site/**": true,
  },
