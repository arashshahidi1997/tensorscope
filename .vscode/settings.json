{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "search.exclude": {
        "**/resources/**": true,
        "**/frontend/node_modules/**": true,
        "**/frontend/dist/**": true,
        "**/docs/reference-studies/my-awesome-app/node_modules/**": true,
        "**/docs/reference-studies/my-awesome-app/dist/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/*.egg-info/**": true,
        "**/*.tsbuildinfo": true
    }

  // >>> projio >>>
